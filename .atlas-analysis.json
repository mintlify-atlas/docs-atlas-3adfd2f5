  "keyFeatures": [
    "Named-pipe IPC via TerbinCommunicator for client-server communication",
    "Reflection-based executable dispatcher using [TerbinExecutable] attribute",
    "Binary packet protocol with fragmentation support for large payloads",
    "Plugin management: download, install, uninstall, and enumerate mods per instance",
    "Game instance lifecycle management (create, delete, list, get)",
    "Plugin storage registry with reference tracking",
    "Custom binary serialization with BufferWriter/BufferReader and Span-based API",
    "Thread-safe in-memory fragment assembly via TerbinMemory",
    "Steam/Proton integration and Farlands game launcher utilities",
    "Progress reporting for long-running operations (download, install)"
  ],
